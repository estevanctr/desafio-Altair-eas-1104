generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("users")
}

model Process {
  id                 String   @id @default(uuid())
  processNumber      String   @unique
  courtAcronym       String
  organName          String

  hasFinalJudgment   Boolean  @default(false)

  communications     Communication[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([processNumber])
  @@index([courtAcronym])
  @@map("processes")
}

enum CommunicationSource {
  DIARIO
  EDITAL
}

model Communication {
  id                String               @id @default(uuid())
  externalId        Int                  @unique
  publicationDate   DateTime
  communicationType String
  content           String               @db.Text
  source            CommunicationSource?

  aiSummary         String?              @db.Text

  processId         String
  process           Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  recipients        Recipient[]

  createdAt         DateTime @default(now())

  @@index([processId])
  @@index([publicationDate])
  @@index([externalId])
  
  @@map("communications")
}

model Recipient {
  id              String  @id @default(uuid())
  name            String
  role            String?
  oabNumber       String?
  oabState        String?
  isLawyer        Boolean @default(false)

  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@map("recipients")
}

enum CronRunStatus {
  SUCCESS
  PARTIAL_FAILURE
  FAILED
}

model CronRun {
  id            String         @id @default(uuid())
  jobName       String
  referenceDate String
  startedAt     DateTime
  finishedAt    DateTime
  durationMs    Int
  status        CronRunStatus
  fetched       Int            @default(0)
  created       Int            @default(0)
  skipped       Int            @default(0)
  failed        Int            @default(0)
  errorMessage  String?        @db.Text

  organs        CronRunOrgan[]

  createdAt     DateTime       @default(now())

  @@index([jobName, startedAt])
  @@index([status])
  @@map("cron_runs")
}

model CronRunOrgan {
  id            String  @id @default(uuid())
  runId         String
  run           CronRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  label         String
  courtAcronym  String
  organId       Int
  fetched       Int     @default(0)
  created       Int     @default(0)
  skipped       Int     @default(0)
  failed        Int     @default(0)
  errorMessage  String? @db.Text

  @@index([runId])
  @@map("cron_run_organs")
}
