# Postgres
POSTGRES_USER=juscash
POSTGRES_PASSWORD=juscash
POSTGRES_DB=juscash
DB_PORT=5432

# API
API_PORT=3333
NODE_ENV=local
# Só usado quando a API roda fora do Docker (npm run start:dev).
# No compose, DATABASE_URL é sobrescrito para apontar ao serviço `postgres`.
DATABASE_URL=postgresql://juscash:juscash@localhost:5432/juscash
HASH_SALT_ROUNDS=10
PROCESS_COMMUNICATIONS_API_URL=https://comunicaapi.pje.jus.br/api/v1/comunicacao
JWT_ACCESS_TOKEN_EXPIRES_IN=2h
JWT_PRIVATE_KEY=base64-encoded-rsa-private-key
JWT_PUBLIC_KEY=base64-encoded-rsa-public-key
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Web
WEB_PORT=3000
AUTH_SECRET=S9EqMM6kxDrhdwUnD6XPQoW6CxO6YWwI7giEhW4cyLs=
